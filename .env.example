# Copy to .env and fill in real values. NEVER commit .env (it is git-ignored).

# ---- Voice pipeline (required) ----
GROQ_API_KEY=                 # Groq Whisper STT + dialogue LLM (llama-3.3-70b)
SARVAM_API_KEY=               # Sarvam TTS (bulbul:v3)
GOOGLE_API_KEY=               # Gemini — STT fallback only (dialogue runs on Groq)

# ---- Persistence: Google Sheets + Calendar (required) ----
# base64 of the ENTIRE service-account JSON key file:
#   Git Bash:  base64 -w0 service-account.json
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEETS_ID=             # spreadsheet ID from its URL
GOOGLE_CALENDAR_ID=           # calendar ID (…@group.calendar.google.com)
# The service-account email must have Editor on the Sheet and
# "Make changes to events" on the Calendar.

# ---- Admin dashboard auth (optional; only needed for /admin) ----
AUTH_SECRET=                  # openssl rand -base64 32
AUTH_TRUST_HOST=true          # required when NOT hosted on Vercel (e.g. Render)
GOOGLE_CLIENT_ID=             # Google OAuth client (for admin login)
GOOGLE_CLIENT_SECRET=
